{
	"name": "image-magick",
	"version": "1.0.1",
	"description": "Resize, crop, rotate, compress and convert images inside Obsidian.",
	"author": "Abdulkader Safi <safi.abdulkader@gmail.com> (https://abdulkadersafi.com)",
	"repository": {
		"type": "git",
		"url": "https://github.com/Abdulkader-Safi/obsidian-image-magick-plugins"
	},
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node --test test/*.test.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"imagemagick",
		"image",
		"optimize",
		"compress",
		"resize",
		"crop",
		"webp",
		"convert"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"esbuild-svelte": "^0.9.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"svelte": "^5.56.3",
		"svelte-preprocess": "^6.0.5",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	},
	"dependencies": {
		"fflate": "^0.8.3",
		"safi-image": "^0.1.0"
	}
}
