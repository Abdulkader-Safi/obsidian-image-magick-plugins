{
	"name": "svelte-plugin-template",
	"version": "1.0.0",
	"description": "A starter template for building Obsidian plugins with Svelte, Tailwind, and shadcn-svelte.",
	"author": "Abdulkader Safi <safi.abdulkader@gmail.com> (https://abdulkadersafi.com)",
	"repository": {
		"type": "git",
		"url": "https://github.com/AbdulkaderSafi/svelte-plugin-template"
	},
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "run-p dev:js dev:css",
		"dev:js": "node esbuild.config.mjs",
		"dev:css": "tailwindcss -i src/styles.css -o styles.css --watch",
		"build": "tsc -noEmit -skipLibCheck && run-s build:css build:js",
		"build:js": "node esbuild.config.mjs production",
		"build:css": "tailwindcss -i src/styles.css -o styles.css --minify",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"svelte",
		"tailwindcss",
		"shadcn",
		"template",
		"starter-kit"
	],
	"license": "0BSD",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@tailwindcss/cli": "^4.3.1",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"esbuild-svelte": "^0.9.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"npm-run-all": "^4.1.5",
		"obsidian": "latest",
		"svelte": "^5.56.3",
		"svelte-preprocess": "^6.0.5",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2"
	}
}
